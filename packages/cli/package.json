{
	"name": "@logic-md/cli",
	"version": "1.4.0",
	"description": "CLI for validating, linting, compiling, and scaffolding LOGIC.md reasoning specifications",
	"type": "module",
	"bin": {
		"logic-md": "dist/cli.js"
	},
	"exports": {
		".": "./dist/cli.js"
	},
	"files": [
		"dist",
		"templates"
	],
	"scripts": {
		"build": "tsup",
		"postbuild": "chmod +x dist/cli.js && cp ../core/schema.json dist/schema.json 2>/dev/null || cp ../core/dist/schema.json dist/schema.json 2>/dev/null || true",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "biome check ."
	},
	"dependencies": {
		"@logic-md/core": "*",
		"chokidar": "^5.0.0",
		"commander": "^14.0.0",
		"microdiff": "^1.5.0",
		"picocolors": "^1.1.0",
		"tinyglobby": "^0.2.16"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"tsup": "^8.0.0",
		"typescript": "^6.0.3",
		"vitest": "~4.1.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SingularityAI-Dev/logic-md.git",
		"directory": "packages/cli"
	},
	"keywords": [
		"logic-md",
		"cli",
		"ai-agents",
		"reasoning",
		"validate",
		"lint",
		"compile"
	],
	"engines": {
		"node": ">=18"
	}
}
