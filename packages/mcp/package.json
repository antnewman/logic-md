{
	"name": "@logic-md/mcp",
	"version": "1.4.0",
	"description": "MCP server exposing LOGIC.md tools for parsing, validating, linting, and compiling reasoning specifications",
	"type": "module",
	"bin": {
		"logic-md-mcp": "dist/index.js"
	},
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist",
		"templates"
	],
	"scripts": {
		"build": "tsup",
		"postbuild": "chmod +x dist/index.js && cp ../core/schema.json dist/schema.json 2>/dev/null || cp ../core/dist/schema.json dist/schema.json 2>/dev/null || true",
		"dev": "tsup --watch",
		"test": "node --test tests/server.test.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "biome check ."
	},
	"dependencies": {
		"@logic-md/core": "*",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SingularityAI-Dev/logic-md.git",
		"directory": "packages/mcp"
	},
	"keywords": [
		"logic-md",
		"mcp",
		"model-context-protocol",
		"ai-agents",
		"reasoning"
	],
	"engines": {
		"node": ">=18"
	}
}
