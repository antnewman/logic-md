{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LOGIC.md",
  "scopeName": "text.logic-md",
  "fileTypes": ["logic.md"],
  "patterns": [
    {
      "include": "#frontmatter"
    },
    {
      "include": "#markdown"
    }
  ],
  "repository": {
    "frontmatter": {
      "name": "meta.frontmatter.logic-md",
      "begin": "^(---)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.frontmatter.logic-md"
        }
      },
      "end": "^(---)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.frontmatter.logic-md"
        }
      },
      "patterns": [
        {
          "include": "#yaml-content"
        }
      ]
    },
    "yaml-content": {
      "patterns": [
        {
          "include": "#yaml-comment"
        },
        {
          "include": "#logic-keys"
        },
        {
          "include": "#yaml-basic-types"
        }
      ]
    },
    "yaml-comment": {
      "name": "comment.line.hash.yaml",
      "match": "^\\s*#.*$"
    },
    "logic-keys": {
      "patterns": [
        {
          "name": "variable.other.logic-key.core",
          "match": "^\\s*(spec_version|name|description|reasoning|steps|contracts|quality_gates|fallback|decision_trees|global|imports)(?=:)"
        },
        {
          "name": "variable.other.logic-key.step",
          "match": "^\\s*(needs|instructions|branches|verification|retry|timeout|allowed_tools|denied_tools|output_schema|input_schema|handler)(?=:)"
        },
        {
          "name": "variable.other.logic-key.contract",
          "match": "^\\s*(input_schema|output_schema|invariants|preconditions|postconditions|error_handling|sla|severity)(?=:)"
        },
        {
          "name": "variable.other.logic-key.decision-tree",
          "match": "^\\s*(condition|then_step|else_step|default_step|decision_id)(?=:)"
        },
        {
          "name": "variable.other.logic-key.gate",
          "match": "^\\s*(metric|threshold|on_fail|severity|message)(?=:)"
        },
        {
          "name": "variable.other.logic-key.branch",
          "match": "^\\s*(condition|target|target_id)(?=:)"
        },
        {
          "name": "variable.other.logic-key.retry",
          "match": "^\\s*(max_attempts|delay|backoff|backoff_factor)(?=:)"
        },
        {
          "name": "variable.other.logic-key.fallback",
          "match": "^\\s*(step|steps|decision_tree|message|action)(?=:)"
        },
        {
          "name": "invalid.deprecated",
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_-]*)(?=:)(?!\\s*(spec_version|name|description|reasoning|steps|contracts|quality_gates|fallback|decision_trees|global|imports|needs|instructions|branches|verification|retry|timeout|allowed_tools|denied_tools|output_schema|input_schema|handler|input_schema|output_schema|invariants|preconditions|postconditions|error_handling|sla|severity|condition|then_step|else_step|default_step|decision_id|metric|threshold|on_fail|message|target|target_id|max_attempts|delay|backoff|backoff_factor|step|steps|decision_tree|action))"
        }
      ]
    },
    "yaml-basic-types": {
      "patterns": [
        {
          "include": "#yaml-string"
        },
        {
          "include": "#yaml-number"
        },
        {
          "include": "#yaml-boolean"
        },
        {
          "include": "#yaml-null"
        },
        {
          "include": "#yaml-array"
        },
        {
          "include": "#yaml-object"
        },
        {
          "include": "#expression"
        }
      ]
    },
    "yaml-string": {
      "patterns": [
        {
          "name": "string.quoted.double.yaml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.yaml",
              "match": "\\\\."
            },
            {
              "include": "#expression"
            }
          ]
        },
        {
          "name": "string.quoted.single.yaml",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.yaml",
              "match": "''"
            }
          ]
        },
        {
          "name": "string.unquoted.yaml",
          "match": "(?<=:\\s)([^\\n\\r\\#])*?(?=\\s*$|\\s*#)"
        }
      ]
    },
    "yaml-number": {
      "patterns": [
        {
          "name": "constant.numeric.float.yaml",
          "match": "(?<=[:\\s\\-\\[,])(-)?\\d+(\\.\\d+)?([eE][+-]?\\d+)?(?=[\\s,\\]\\}]|$)"
        }
      ]
    },
    "yaml-boolean": {
      "patterns": [
        {
          "name": "constant.language.boolean.yaml",
          "match": "(?<=[:\\s\\-\\[,])(true|false|yes|no|on|off)(?=[\\s,\\]\\}]|$)"
        }
      ]
    },
    "yaml-null": {
      "patterns": [
        {
          "name": "constant.language.null.yaml",
          "match": "(?<=[:\\s\\-\\[,])(null|~|)(?=[\\s,\\]\\}]|$)"
        }
      ]
    },
    "yaml-array": {
      "name": "meta.structure.array.yaml",
      "begin": "\\[",
      "end": "\\]",
      "patterns": [
        {
          "include": "#yaml-array-element"
        }
      ]
    },
    "yaml-array-element": {
      "patterns": [
        {
          "include": "#yaml-string"
        },
        {
          "include": "#yaml-number"
        },
        {
          "include": "#yaml-boolean"
        },
        {
          "include": "#yaml-null"
        },
        {
          "include": "#expression"
        }
      ]
    },
    "yaml-object": {
      "patterns": [
        {
          "name": "meta.structure.dictionary.yaml",
          "match": "\\{[^\\}]*\\}"
        }
      ]
    },
    "expression": {
      "patterns": [
        {
          "name": "meta.expression.logic-md",
          "begin": "\\{\\{",
          "end": "\\}\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.expression.begin.logic-md"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.expression.end.logic-md"
            }
          },
          "patterns": [
            {
              "include": "#expression-operators"
            },
            {
              "include": "#expression-keywords"
            },
            {
              "include": "#expression-functions"
            },
            {
              "include": "#expression-literals"
            }
          ]
        }
      ]
    },
    "expression-operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.logic-md",
          "match": "\\b(and|or|not|in)\\b"
        },
        {
          "name": "keyword.operator.comparison.logic-md",
          "match": "(===|!==|==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.logic-md",
          "match": "(\\+|-|\\*|/|%|\\^)"
        },
        {
          "name": "keyword.operator.assignment.logic-md",
          "match": "="
        }
      ]
    },
    "expression-keywords": {
      "patterns": [
        {
          "name": "keyword.control.logic-md",
          "match": "\\b(if|then|else|switch|case|default|for|while|do|break|continue|return)\\b"
        }
      ]
    },
    "expression-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.logic-md",
          "match": "\\b(len|type|keys|values|has|get|set|push|pop|shift|unshift|slice|join|split|contains|startsWith|endsWith|toLowerCase|toUpperCase|trim|replace|match|round|floor|ceil|abs|min|max|sum|avg|count|distinct|sort|reverse|filter|map|reduce|group|unique|flatten|compact)\\b"
        }
      ]
    },
    "expression-literals": {
      "patterns": [
        {
          "name": "constant.numeric.logic-md",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "string.quoted.double.logic-md",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.logic-md",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.logic-md",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.logic-md",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "constant.language.logic-md",
          "match": "\\b(true|false|null|undefined)\\b"
        },
        {
          "name": "variable.other.logic-md",
          "match": "\\$?[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "reasoning-strategies": {
      "patterns": [
        {
          "name": "constant.language.reasoning-strategy",
          "match": "\\b(cot|react|tot|got|plan-execute|custom)\\b"
        }
      ]
    },
    "on-fail-values": {
      "patterns": [
        {
          "name": "constant.language.on-fail",
          "match": "\\b(retry|escalate|skip|abort|revise)\\b"
        }
      ]
    },
    "severity-values": {
      "patterns": [
        {
          "name": "constant.language.severity",
          "match": "\\b(error|warning|info)\\b"
        }
      ]
    },
    "markdown": {
      "name": "text.markdown.logic-md",
      "patterns": [
        {
          "include": "#markdown-heading"
        },
        {
          "include": "#markdown-bold"
        },
        {
          "include": "#markdown-italic"
        },
        {
          "include": "#markdown-code"
        },
        {
          "include": "#markdown-link"
        },
        {
          "include": "#markdown-list"
        },
        {
          "include": "#expression"
        }
      ]
    },
    "markdown-heading": {
      "name": "markup.heading.markdown",
      "match": "^(#{1,6})\\s+(.+?)$",
      "captures": {
        "1": {
          "name": "punctuation.definition.heading.markdown"
        }
      }
    },
    "markdown-bold": {
      "name": "markup.bold.markdown",
      "match": "\\*\\*[^*]+\\*\\*|__[^_]+__"
    },
    "markdown-italic": {
      "name": "markup.italic.markdown",
      "match": "\\*[^*]+\\*|_[^_]+_"
    },
    "markdown-code": {
      "patterns": [
        {
          "name": "markup.inline.raw.string.markdown",
          "match": "`[^`]+`"
        },
        {
          "name": "markup.raw.block.markdown",
          "begin": "^```",
          "end": "^```"
        }
      ]
    },
    "markdown-link": {
      "name": "meta.link.inline.markdown",
      "match": "\\[([^\\]]+)\\]\\(([^\\)]+)\\)"
    },
    "markdown-list": {
      "patterns": [
        {
          "name": "markup.list.unnumbered.markdown",
          "match": "^\\s*[-*+]\\s+"
        },
        {
          "name": "markup.list.numbered.markdown",
          "match": "^\\s*\\d+\\.\\s+"
        }
      ]
    }
  }
}
