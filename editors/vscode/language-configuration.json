{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["{{", "}}"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*---\\s*$",
      "end": "^\\s*---\\s*$"
    }
  },
  "wordPattern": "(-?\\d+\\.\\d+\\w*)|([^\\`\\~\\!\\@\\#\\$\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(steps|contracts|quality_gates|decision_trees|global|imports|fallback|branches|needs|verification|allowed_tools|denied_tools|preconditions|postconditions|invariants|then|else|for|while|if|else if)\\s*:\\s*.*$",
    "decreaseIndentPattern": "^\\s*-?\\s*([a-zA-Z_][a-zA-Z0-9_-]*)\\s*:"
  }
}
